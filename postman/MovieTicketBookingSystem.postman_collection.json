          "const future = new Date(Date.now() + 3 * 24 * 60 * 60 * 1000);",
          "pm.collectionVariables.set('futureShowTime', future.toISOString().slice(0, 19));",
          "pm.collectionVariables.set('uniqueSuffix', Date.now().toString());"
